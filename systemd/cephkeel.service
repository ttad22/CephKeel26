[Unit]
Description=CephKeel adaptive network-aware controller
After=network.target ceph.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/cephkeel_controller.py --interval 5
Restart=on-failure
RestartSec=5
User=root
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
